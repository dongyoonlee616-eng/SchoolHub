<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>관리자 게시판 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>
  <main class="container">
    <a href="/admin" class="back-link">← 관리자 대시보드로 돌아가기</a>

    <div class="admin-page-header">
      <div>
        <h1>게시판 관리</h1>
        <p>모든 게시물을 확인하고 관리합니다.</p>
      </div>
    </div>

    <section class="admin-board-tools">
      <div class="category-filter">
        <a 
          href="/admin/board<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '' %>"
          class="filter-chip <%= !selectedStatus ? 'active' : '' %>"
        >
          전체
        </a>

        <a 
          href="/admin/board?status=approved<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"
          class="filter-chip <%= selectedStatus === 'approved' ? 'active' : '' %>"
        >
          승인됨
        </a>

        <a 
          href="/admin/board?status=pending<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"
          class="filter-chip <%= selectedStatus === 'pending' ? 'active' : '' %>"
        >
          승인 대기
        </a>
      </div>

      <form class="admin-board-search" action="/admin/board" method="GET">
        <% if (selectedStatus) { %>
          <input type="hidden" name="status" value="<%= selectedStatus %>" />
        <% } %>

        <input 
          type="text" 
          name="q" 
          value="<%= searchQuery %>" 
          placeholder="제목, 내용, 작성자 검색"
          autocomplete="off"
        />

        <button type="submit">검색</button>

        <% if (selectedStatus || searchQuery) { %>
          <a href="/admin/board" class="reset-search">초기화</a>
        <% } %>
      </form>
    </section>

    <% if (posts.length === 0) { %>
      <div class="empty-box">
        조건에 맞는 게시물이 없습니다.
      </div>
    <% } else { %>
      <div class="admin-board-list">
        <% posts.forEach(post => { %>
          <a href="/admin/board/posts/<%= post.id %>" class="admin-board-row">
            <div>
              <div class="admin-board-row-meta">
                <span><%= post.school_name %></span>
                <span><%= post.category %></span>
                <span class="<%= post.status === 'approved' ? 'status-approved' : 'status-pending' %>">
                  <%= post.status === 'approved' ? '승인됨' : '승인 대기' %>
                </span>
              </div>

              <h2><%= post.title %></h2>
              <p>작성자: <%= post.nickname %> · 댓글 <%= post.comment_count %>개</p>
            </div>

            <strong>관리</strong>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include("../partials/admin-footer") %>
</body>
</html>