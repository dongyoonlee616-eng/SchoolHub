<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>댓글 검토 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>
  <main class="container">
    <a href="/admin/schools/<%= school.slug %>/comments/pending" class="back-link">← 승인 대기 댓글 목록으로 돌아가기</a>

    <section class="comment-review-layout">
      <article class="review-post-card">
        <span class="review-label">댓글이 작성된 게시글</span>

        <h1><%= item.post_title %></h1>

        <div class="review-meta">
          <span>학교: <%= item.school_name %></span>
          <span>작성자: <%= item.post_nickname %></span>
          <span>작성일: <%= new Date(item.post_created_at).toLocaleString("ko-KR") %></span>
        </div>

        <p class="review-post-content"><%= item.post_content %></p>
      </article>

      <aside class="review-comment-card">
        <span class="review-label">승인 대기 댓글</span>

        <div class="review-comment-meta">
          <strong><%= item.nickname %></strong>
          <span><%= new Date(item.created_at).toLocaleString("ko-KR") %></span>
        </div>

        <p><%= item.content %></p>

        <div class="review-actions">
          <form action="/admin/schools/<%= school.slug %>/comments/<%= item.id %>/approve" method="POST">
            <button type="submit" class="approve-button">댓글 승인</button>
          </form>

          <form
            action="/admin/schools/<%= school.slug %>/comments/<%= comment.id %>/reject"
            method="POST"
            onsubmit="return confirm('이 댓글을 거절하시겠습니까?');"
          >
            <button type="submit" class="reject-button">거절</button>
          </form>
        </div>
      </aside>
    </section>
  </main>
  <script src="/js/confirm-delete.js"></script>
  <%- include("../partials/admin-footer") %>
</body>
</html>