<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>학교 추가 - SchoolHub</title>

  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>

  <main class="container">
    <a href="/admin/schools">← 학교 관리로 돌아가기</a>

    <section class="admin-page-header">
      <div>
        <h1>학교 추가</h1>
        <p>새 학교 커뮤니티를 추가합니다.</p>
      </div>
    </section>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/admin/schools" method="POST" class="notice-form">
      <label>
        학교 이름
        <input
          type="text"
          name="name"
          placeholder="예: 근명중학교"
          required
        />
      </label>

      <label>
        학교 slug
        <input
          type="text"
          name="slug"
          placeholder="예: geunmyeong-middle"
          required
        />
      </label>

      <label class="checkbox-label">
        <input type="checkbox" name="is_active" checked />
        <span>사용자 화면에 표시</span>
      </label>

      <button type="submit">학교 추가</button>
    </form>
  </main>

  <%- include("../partials/admin-footer") %>
</body>
</html>