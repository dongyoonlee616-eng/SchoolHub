<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>학교 관리 - SchoolHub</title>

  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/superadmin-header") %>

  <main class="container">
    <a href="/superadmin" class="back-link">← 관리자 대시보드로 돌아가기</a>

    <section class="admin-page-header">
      <div>
        <h1>학교 관리</h1>
        <p>SchoolHub에 등록된 학교를 추가, 수정, 비활성화할 수 있습니다.</p>
      </div>

      <a href="/admin/schools/new" class="admin-write-button">학교 추가</a>
    </section>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <% if (schools.length === 0) { %>
      <div class="school-admin-empty">
        등록된 학교가 없습니다.
      </div>
    <% } else { %>
      <div class="school-admin-list">
        <% schools.forEach(school => { %>
          <%
            const postsCount = Number(school.posts_count || 0);
            const commentsCount = Number(school.comments_count || 0);
            const noticesCount = Number(school.notices_count || 0);
            const lostItemsCount = Number(school.lost_items_count || 0);
            const totalContentCount = postsCount + commentsCount + noticesCount + lostItemsCount;
          %>

          <article class="school-admin-card">
            <div class="school-admin-card-top">
              <span class="school-status-badge <%= school.is_active ? 'active' : 'inactive' %>">
                <%= school.is_active ? "활성" : "비활성" %>
              </span>

              <div class="school-admin-actions">
                <a href="/admin/schools/<%= school.id %>/edit">수정</a>

                <form action="/admin/schools/<%= school.id %>/toggle" method="POST">
                  <button type="submit">
                    <%= school.is_active ? "비활성화" : "활성화" %>
                  </button>
                </form>

                <% if (totalContentCount === 0) { %>
                  <form action="/admin/schools/<%= school.id %>/delete" method="POST">
                    <button type="submit" class="delete-school-button">삭제</button>
                  </form>
                <% } %>
              </div>
            </div>

            <h2><%= school.name %></h2>

            <div class="school-admin-info">
              <div>
                <span>slug</span>
                <strong><%= school.slug %></strong>
              </div>

              <div>
                <span>게시글</span>
                <strong><%= postsCount %>개</strong>
              </div>

              <div>
                <span>댓글</span>
                <strong><%= commentsCount %>개</strong>
              </div>

              <div>
                <span>공지</span>
                <strong><%= noticesCount %>개</strong>
              </div>

              <div>
                <span>분실물</span>
                <strong><%= lostItemsCount %>개</strong>
              </div>
            </div>

            <div class="school-admin-date">
              <span>
                생성일:
                <%= new Date(school.created_at).toLocaleString("ko-KR") %>
              </span>

              <% if (school.updated_at) { %>
                <span>
                  수정일:
                  <%= new Date(school.updated_at).toLocaleString("ko-KR") %>
                </span>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include("../partials/admin-footer") %>
  <script src="/js/confirm-delete.js"></script>
</body>
</html>