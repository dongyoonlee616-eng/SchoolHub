<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>학교 관리 - SchoolHub</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>

  <main class="container">
    <a href="/admin">← 관리자 대시보드로 돌아가기</a>

    <section class="admin-page-header">
      <div>
        <h1>학교 관리</h1>
        <p>SchoolHub에 등록된 학교를 추가, 수정, 비활성화할 수 있습니다.</p>
      </div>

      <a href="/admin/schools/new" class="admin-write-button">학교 추가</a>
    </section>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <% if (schools.length === 0) { %>
      <div class="notice-admin-list">
        <div class="notice-admin-card">
          <p>등록된 학교가 없습니다.</p>
        </div>
      </div>
    <% } else { %>
      <div class="notice-admin-list">
        <% schools.forEach(school => { %>
          <article class="notice-admin-card">
            <div>
              <% if (school.is_active) { %>
                <span class="notice-school status-approved">활성</span>
              <% } else { %>
                <span class="notice-school status-pending">비활성</span>
              <% } %>

              <h2><%= school.name %></h2>

              <p>
                slug:
                <strong><%= school.slug %></strong>
              </p>

              <p>
                게시글 <%= school.posts_count %>개 /
                공지 <%= school.notices_count %>개 /
                분실물 <%= school.lost_items_count %>개
              </p>

              <small>
                생성일:
                <%= new Date(school.created_at).toLocaleString("ko-KR") %>
              </small>

              <% if (school.updated_at) { %>
                <br />
                <small>
                  수정일:
                  <%= new Date(school.updated_at).toLocaleString("ko-KR") %>
                </small>
              <% } %>
            </div>

            <div class="notice-admin-actions school-admin-actions">
              <a href="/admin/schools/<%= school.id %>/edit">수정</a>

              <form action="/admin/schools/<%= school.id %>/toggle" method="POST">
                <button type="submit" class="toggle-button">
                  <% if (school.is_active) { %>
                    비활성화
                  <% } else { %>
                    활성화
                  <% } %>
                </button>
              </form>

              <form action="/admin/schools/<%= school.id %>/delete" method="POST">
                <button type="submit">삭제</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </main>

  <%- include("../partials/admin-footer") %>

  <script src="/js/confirm-delete.js"></script>
</body>
</html>