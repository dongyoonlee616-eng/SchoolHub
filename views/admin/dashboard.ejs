<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>관리자 메인 - SchoolHub</title>

  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/index.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>

  <main class="home-container">
    <section class="hero-section">
      <div class="hero-text">
        <span class="hero-badge">ADMIN</span>
        <h1>SchoolHub Admin</h1>

        <p>
          관리할 학교를 선택하세요. 학교별로 게시글, 댓글, 공지사항, 분실물을 따로 관리할 수 있습니다.
        </p>

        <div class="hero-actions">
          <a href="#adminSchoolList" class="primary-action">학교 선택하기</a>
          <a href="/admin/schools" class="secondary-action">학교 관리</a>
        </div>
      </div>

      <div class="hero-card">
        <div class="hero-card-top">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <h2>학교별 관리 모드</h2>
        <p>
          v1.1.0부터는 학교를 먼저 선택한 뒤 해당 학교의 관리자 기능으로 이동합니다.
        </p>

        <div class="hero-mini-grid">
          <div>
            <strong>학교 선택</strong>
            <span>관리 대상 선택</span>
          </div>

          <div>
            <strong>분리 관리</strong>
            <span>학교별 대시보드</span>
          </div>

          <div>
            <strong>운영 안정화</strong>
            <span>관리 혼동 방지</span>
          </div>
        </div>
      </div>
    </section>

    <section class="school-section" id="adminSchoolList">
      <div class="section-header">
        <div>
          <span class="section-label">SELECT SCHOOL</span>
          <h2>학교 선택</h2>
          <p>관리할 학교의 관리자 대시보드로 이동하세요.</p>
        </div>

        <div class="search-box">
          <input
            type="text"
            id="schoolSearchInput"
            placeholder="학교 이름 검색"
          />
        </div>
      </div>

      <% if (schools.length === 0) { %>
        <div class="no-result" style="display:block;">
          등록된 학교가 없습니다. 학교 관리에서 학교를 추가하세요.
        </div>
      <% } else { %>
        <div class="school-list" id="schoolList">
          <% schools.forEach(school => { %>
            <a
              href="/admin/schools/<%= school.slug %>/dashboard"
              class="school-card"
              data-school-name="<%= school.name %>"
            >
              <div>
                <% if (school.is_active) { %>
                  <span class="school-badge">활성</span>
                <% } else { %>
                  <span class="school-badge">비활성</span>
                <% } %>

                <h3><%= school.name %></h3>

                <p>
                  게시글 <%= school.posts_count %>개 /
                  댓글 <%= school.comments_count %>개 /
                  공지 <%= school.notices_count %>개 /
                  분실물 <%= school.lost_items_count %>개
                </p>
              </div>
            </a>
          <% }) %>
        </div>

        <div class="no-result" id="schoolNoResult">
          검색 결과가 없습니다.
        </div>
      <% } %>
    </section>
  </main>

  <%- include("../partials/admin-footer") %>

  <script>
    const searchInput = document.getElementById("schoolSearchInput");
    const schoolCards = document.querySelectorAll(".school-card");
    const noResult = document.getElementById("schoolNoResult");

    if (searchInput) {
      searchInput.addEventListener("input", () => {
        const keyword = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        schoolCards.forEach((card) => {
          const schoolName = card.dataset.schoolName.toLowerCase();

          if (schoolName.includes(keyword)) {
            card.style.display = "block";
            visibleCount += 1;
          } else {
            card.style.display = "none";
          }
        });

        if (noResult) {
          noResult.style.display = visibleCount === 0 ? "block" : "none";
        }
      });
    }
  </script>
</body>
</html>