<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>건의사항 관리 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <%- include("../partials/admin-header") %>
  <main class="container">
    <a href="/admin" class="back-link">← 관리자 대시보드로 돌아가기</a>

    <div class="admin-page-header">
      <div>
        <h1>건의사항 관리</h1>
        <p>사용자가 제출한 SchoolHub 개선 의견을 확인합니다.</p>
      </div>
    </div>

    <% if (suggestions.length === 0) { %>
      <div class="empty-box">
        접수된 건의사항이 없습니다.
      </div>
    <% } else { %>
      <div class="suggestion-admin-list">
        <% suggestions.forEach(item => { %>
          <article class="suggestion-admin-card <%= item.status === 'unread' ? 'unread-suggestion' : '' %>">
            <div class="suggestion-admin-meta">
              <span><%= item.status === 'unread' ? '미확인' : '확인됨' %></span>
              <span>작성자: <%= item.nickname %></span>
              <span><%= new Date(item.created_at).toLocaleString("ko-KR") %></span>
            </div>

            <p><%= item.content %></p>

            <div class="notice-admin-actions">
              <% if (item.status === 'unread') { %>
                <form action="/admin/suggestions/<%= item.id %>/read" method="POST">
                  <button type="submit" class="read-button">확인 처리</button>
                </form>
              <% } %>

              <form action="/admin/suggestions/<%= item.id %>/delete" method="POST">
                <button type="submit">삭제</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </main>
  <script src="/js/confirm-delete.js"></script>
  <%- include("../partials/admin-footer") %>
</body>
</html>