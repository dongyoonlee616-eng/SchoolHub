<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= school.name %> 게시판 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/posts.css" />
</head>
<body>
  <%- include("partials/header", { school: typeof school !== "undefined" ? school : null }) %>
  <main class="container">
    <a href="/schools/<%= school.slug %>" class="back-link">
      ← 커뮤니티로 돌아가기
    </a>

    <div class="page-header">
      <div>
        <h1><%= school.name %> 게시판</h1>
        <p>승인된 게시글만 공개됩니다.</p>
      </div>

      <a href="/schools/<%= school.slug %>/posts/new" class="write-button">
        글쓰기
      </a>
    </div>

    <section class="post-tools">
      <div class="category-filter">
        <a 
          href="/schools/<%= school.slug %>/posts<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '' %>"
          class="filter-chip <%= !selectedCategory ? 'active' : '' %>"
        >
          전체
        </a>

        <% categories.forEach(category => { %>
          <a 
            href="/schools/<%= school.slug %>/posts?category=<%= encodeURIComponent(category) %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"
            class="filter-chip <%= selectedCategory === category ? 'active' : '' %>"
          >
            <%= category %>
          </a>
        <% }) %>
      </div>

        <form 
            class="post-search-form" 
            action="/schools/<%= school.slug %>/posts" 
            method="GET"
            >
            <% if (selectedCategory) { %>
                <input type="hidden" name="category" value="<%= selectedCategory %>" />
            <% } %>

            <select name="searchType">
                <option value="title" <%= selectedSearchType === "title" ? "selected" : "" %>>
                제목
                </option>
                <option value="content" <%= selectedSearchType === "content" ? "selected" : "" %>>
                내용
                </option>
                <option value="nickname" <%= selectedSearchType === "nickname" ? "selected" : "" %>>
                작성자
                </option>
            </select>

            <input 
                type="text" 
                name="q" 
                value="<%= searchQuery %>" 
                placeholder="검색어 입력"
                autocomplete="off"
            />

            <button type="submit">검색</button>

            <% if (selectedCategory || searchQuery) { %>
                <a href="/schools/<%= school.slug %>/posts" class="reset-search">
                초기화
                </a>
            <% } %>
        </form>
    </section>

    <a href="/schools/<%= school.slug %>/posts/guide" class="board-guide-row">
        <div>
            <span>안내</span>
            <h2>게시판 이용 안내</h2>
        </div>
    </a>

    <% if (submitted) { %>
      <div class="notice-box">
        게시글이 제출되었습니다. 관리자 승인 후 게시판에 공개됩니다.
      </div>
    <% } %>

    <% if (edited) { %>
      <div class="notice-box">
        게시글이 수정되었습니다. 관리자 재승인 후 다시 공개됩니다.
      </div>
    <% } %>

    <% if (deleted) { %>
      <div class="notice-box">
        게시글이 삭제되었습니다.
      </div>
    <% } %>

    <% if (posts.length === 0) { %>
      <div class="empty-box">
        조건에 맞는 게시글이 없습니다.
      </div>
    <% } else { %>
      <div class="post-list">
        <% posts.forEach(post => { %>
          <a class="post-row" href="/schools/<%= school.slug %>/posts/<%= post.id %>">
            <h2><%= post.title %></h2>
            <p>작성자: <%= post.nickname %></p>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include("partials/footer") %>
</body>
</html>