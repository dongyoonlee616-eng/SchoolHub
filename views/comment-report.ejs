<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>댓글 신고 - SchoolHub</title>

  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/post-new.css" />
</head>
<body>
  <%- include("partials/header", { school }) %>

  <main class="container">
    <a href="/schools/<%= school.slug %>/posts/<%= comment.post_id %>" class="back-link">
      ← 게시글로 돌아가기
    </a>

    <section class="post-form-section">
      <div class="post-form-header">
        <h1>댓글 신고</h1>
        <p>부적절한 댓글을 관리자에게 신고할 수 있습니다.</p>
      </div>

      <div class="notice-box">
        신고 대상 게시글: <strong><%= comment.post_title %></strong>
      </div>

      <div class="notice-box">
        신고 대상 댓글:
        <br />
        <strong><%= comment.content %></strong>
      </div>

      <% if (error) { %>
        <div class="error-box">
          <%= error %>
        </div>
      <% } %>

      <form
        action="/schools/<%= school.slug %>/posts/<%= comment.post_id %>/comments/<%= comment.id %>/report"
        method="POST"
        class="post-form"
      >
        <label>
          신고자 닉네임
          <input
            type="text"
            name="reporter_nickname"
            placeholder="비워두면 익명으로 신고됩니다."
          />
        </label>

        <label>
          신고 사유
          <select name="reason" required>
            <option value="">신고 사유를 선택하세요</option>
            <option value="욕설/비방">욕설/비방</option>
            <option value="개인정보 노출">개인정보 노출</option>
            <option value="허위사실">허위사실</option>
            <option value="도배/스팸">도배/스팸</option>
            <option value="기타">기타</option>
          </select>
        </label>

        <label>
          상세 내용
          <textarea
            name="content"
            placeholder="신고 사유를 자세히 적어주세요."
            required
          ></textarea>
        </label>

        <button type="submit" id="reportSubmitButton">신고 제출</button>
      </form>
    </section>
  </main>

  <%- include("partials/footer") %>

  <script>
    const reportForm = document.querySelector(".post-form");
    const reportSubmitButton = document.getElementById("reportSubmitButton");

    if (reportForm && reportSubmitButton) {
        reportForm.addEventListener("submit", () => {
        reportSubmitButton.disabled = true;
        reportSubmitButton.textContent = "제출 중...";
        });
    }
    </script>
</body>
</html>