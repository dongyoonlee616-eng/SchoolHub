<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>내 문의 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/mypage.css" />
</head>
<body>
  <%- include("../partials/header", { school: null }) %>

  <main class="container">
    <a href="/" class="back-link">← 메인으로 돌아가기</a>

    <section class="mypage-hero">
      <div>
        <span class="mypage-label">MY SUPPORT</span>
        <h1>내 문의</h1>
        <p>내가 보낸 문의, 건의, 버그 제보 내역을 확인할 수 있습니다.</p>
      </div>

      <div class="mypage-profile-card">
        <strong><%= user.nickname %></strong>
        <span><%= user.email %></span>
        <em>문의 내역</em>
      </div>
    </section>

    <%- include("_nav", { activePage: "support" }) %>

    <section class="mypage-section">
      <div class="mypage-section-header">
        <h2>문의 내역</h2>
        <p>로그인 상태로 제출한 문의만 이곳에 표시됩니다.</p>
      </div>

      <% if (tickets.length === 0) { %>
        <div class="mypage-empty">아직 보낸 문의가 없습니다.</div>
      <% } else { %>
        <div class="mypage-list">
          <% tickets.forEach((ticket) => { %>
            <article class="mypage-row">
              <div>
                <div class="mypage-meta">
                  <span><%= supportTypeLabels[ticket.ticket_type] || ticket.ticket_type %></span>
                  <span class="status-<%= ticket.status %>"><%= supportStatusLabels[ticket.status] || ticket.status %></span>
                </div>
                <h3><%= ticket.title %></h3>
                <p class="mypage-content-preview"><%= ticket.content %></p>

                <% if (ticket.admin_memo) { %>
                  <div class="mypage-admin-memo">
                    <strong>관리자 메모</strong>
                    <p><%= ticket.admin_memo %></p>
                  </div>
                <% } %>

                <p>문의일: <%= new Date(ticket.created_at).toLocaleString("ko-KR") %></p>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
