<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>비밀번호 재설정 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/post-new.css" />
</head>
<body>
  <%- include("../partials/header", { school: null }) %>

  <main class="container">
    <section class="form-hero">
      <span class="form-label">RESET</span>
      <h1>비밀번호 재설정</h1>
      <p>새 비밀번호를 입력해주세요.</p>
    </section>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/reset-password" method="POST" class="post-form">
      <input type="hidden" name="token" value="<%= token %>" />

      <label>
        새 비밀번호
        <input
          type="password"
          name="newPassword"
          autocomplete="new-password"
          placeholder="6자 이상"
          required
        />
      </label>

      <label>
        새 비밀번호 확인
        <input
          type="password"
          name="newPasswordConfirm"
          autocomplete="new-password"
          required
        />
      </label>

      <button type="submit">비밀번호 변경</button>
    </form>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>