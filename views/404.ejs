<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>페이지를 찾을 수 없습니다 - SchoolHub</title>
  <link rel="stylesheet" href="/css/common.css" />
</head>
<body>
  <%- include("partials/header", { school: typeof school !== "undefined" ? school : null }) %>

  <main class="container">
    <section class="not-found-card">
      <span class="not-found-code">404</span>

      <h1><%= typeof title !== "undefined" ? title : "페이지를 찾을 수 없습니다." %></h1>

      <p>
        <%= typeof message !== "undefined" ? message : "주소가 잘못되었거나, 삭제된 페이지일 수 있습니다." %>
      </p>

      <div class="not-found-actions">
        <% if (typeof backUrl !== "undefined" && backUrl) { %>
          <a href="<%= backUrl %>" class="not-found-primary">
            <%= typeof backLabel !== "undefined" ? backLabel : "이전 페이지로 돌아가기" %>
          </a>
        <% } %>

        <a href="/" class="not-found-secondary">
          메인 화면으로 돌아가기
        </a>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>