<header class="admin-site-header">
  <div class="admin-site-header-inner">
    <a href="/admin" class="admin-site-logo">SchoolHub Admin</a>

    <nav class="admin-site-nav">
      <a href="/admin">학교 선택</a>
      <a href="/admin/schools">학교 관리</a>

      <% if (typeof school !== "undefined" && school) { %>
        <a href="/admin/schools/<%= school.slug %>/dashboard">대시보드</a>
        <a href="/admin/schools/<%= school.slug %>/posts/pending">게시글 승인</a>
        <a href="/admin/schools/<%= school.slug %>/comments/pending">댓글 승인</a>
        <a href="/admin/schools/<%= school.slug %>/lost-items/pending">분실물 승인</a>
        <a href="/admin/schools/<%= school.slug %>/notices">공지사항</a>
        <a href="/admin/schools/<%= school.slug %>/board">게시판 관리</a>
        <a href="/admin/schools/<%= school.slug %>/lost-items">분실물 관리</a>
      <% } %>

      <a href="/admin/suggestions">건의사항</a>
    </nav>

    <form action="/admin/logout" method="POST" class="admin-header-logout">
      <button type="submit">로그아웃</button>
    </form>
  </div>
</header>