<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">
      <span class="site-logo-mark">
        <img src="/images/schoolhub-logo.png" alt="SchoolHub 로고" />
      </span>
      <span>SchoolHub</span>
    </a>

    <nav class="site-nav">
      <a href="/">학교 선택</a>

      <% if (typeof school !== "undefined" && school) { %>
        <a href="/schools/<%= school.slug %>">커뮤니티</a>
        <a href="/schools/<%= school.slug %>/posts">게시판</a>
        <a href="/schools/<%= school.slug %>/lost-items">분실물</a>
      <% } %>

      <a href="/support">문의센터</a>

      <% if (currentUser) { %>
        <span class="site-user-badge"><%= currentUser.nickname %>님</span>

        <form action="/logout" method="POST" class="site-logout-form">
          <button type="submit">로그아웃</button>
        </form>
      <% } else { %>
        <a href="/login">로그인</a>
        <a href="/register">회원가입</a>
      <% } %>
    </nav>
  </div>
</header>