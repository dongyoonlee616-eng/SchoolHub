<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">
      <span class="site-logo-mark">
        <img src="/images/schoolhub-logo.png" alt="SchoolHub 로고" />
      </span>
      <span>SchoolHub</span>
    </a>

    <nav class="site-nav">
      <a href="/">학교 선택</a>

      <% if (typeof school !== "undefined" && school) { %>
        <a href="/schools/<%= school.slug %>">커뮤니티</a>
        <a href="/schools/<%= school.slug %>/posts">게시판</a>
        <a href="/schools/<%= school.slug %>/lost-items">분실물</a>
      <% } %>

      <a href="/support">문의센터</a>

      <% if (currentUser) { %>

        <details class="site-nav-dropdown">
          <summary>마이페이지</summary>

          <div class="site-dropdown-menu">
            <a href="/mypage/activity">내 활동</a>
            <a href="/mypage/support">내 문의</a>
            <a href="/mypage/account">계정 정보</a>
          </div>
        </details>
        
        <span class="site-user-badge"><%= currentUser.nickname %>님</span>

        <form action="/logout" method="POST" class="site-logout-form">
          <button type="submit">로그아웃</button>
        </form>

        <% if (currentUser.role === "superadmin") { %>
          <a href="/superadmin">최고 관리자</a>
          <a href="/admin">일반 관리자</a>
        <% } else if (currentUser.role === "admin") { %>
          <a href="/admin">관리자</a>
        <% } %>

      <% } else { %>
        <a href="/login">로그인</a>
        <a href="/register">회원가입</a>
      <% } %>
    </nav>
  </div>
</header>